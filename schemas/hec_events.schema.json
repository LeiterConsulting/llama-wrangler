{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Llama Wrangler HEC Event",
  "type": "object",
  "required": ["timestamp", "event_type", "version"],
  "properties": {
    "timestamp": {"type": "string"},
    "event_type": {"type": "string"},
    "request_id": {"type": "string"},
    "trace_id": {"type": "string"},
    "marshal_node_id": {"type": "string"},
    "node_id": {"type": "string"},
    "version": {"type": "string"},
    "client_name": {"type": "string"},
    "client_type": {"type": "string"},
    "model_requested": {"type": "string"},
    "model_alias": {"type": "string"},
    "resolved_model": {"type": "string"},
    "execution_mode": {"type": "string"},
    "task_type": {"type": "string"},
    "status": {"type": "string"},
    "latency_ms": {"type": "number"},
    "tokens_per_second": {"type": "number"},
    "frontier_used": {"type": "boolean"},
    "fallback_used": {"type": "boolean"},
    "participant_failures": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["node_id", "reason_code", "duration_ms"],
        "properties": {
          "node_id": {"type": "string", "maxLength": 256},
          "reason_code": {
            "type": "string",
            "enum": [
              "missing_proxy_url",
              "connection_error",
              "upstream_4xx",
              "upstream_5xx",
              "body_read_failure",
              "response_size_limit",
              "timeout",
              "cancellation"
            ]
          },
          "status_code": {"type": "integer", "minimum": 100, "maximum": 599},
          "duration_ms": {"type": "integer", "minimum": 0}
        },
        "additionalProperties": false
      }
    },
    "failure_reason_counts": {
      "type": "object",
      "properties": {
        "missing_proxy_url": {"type": "integer", "minimum": 0, "maximum": 8},
        "connection_error": {"type": "integer", "minimum": 0, "maximum": 8},
        "upstream_4xx": {"type": "integer", "minimum": 0, "maximum": 8},
        "upstream_5xx": {"type": "integer", "minimum": 0, "maximum": 8},
        "body_read_failure": {"type": "integer", "minimum": 0, "maximum": 8},
        "response_size_limit": {"type": "integer", "minimum": 0, "maximum": 8},
        "timeout": {"type": "integer", "minimum": 0, "maximum": 8},
        "cancellation": {"type": "integer", "minimum": 0, "maximum": 8}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
